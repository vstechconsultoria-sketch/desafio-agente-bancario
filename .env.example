# =========================================================================
#  Banco Ágil - Configuração de ambiente
#  Copie este arquivo para ".env" e preencha as chaves do provedor escolhido.
# =========================================================================

# Provedor de LLM a ser usado: "groq" (padrão), "google" ou "openai"
LLM_PROVIDER=groq

# Modelo (opcional). Se vazio, usa um padrão sensato por provedor.
# groq:   qwen/qwen3-32b          (padrão: bom tool-calling e cota generosa)
# google: gemini-2.0-flash
# openai: gpt-4o-mini
#
# Alternativas no Groq (camada gratuita):
# - llama-3.3-70b-versatile: ótima qualidade, mas o limite diário de tokens
#   satura rápido em testes longos.
# - llama-3.1-8b-instant: cota alta, porém mais fraco em tool-calling.
LLM_MODEL=

# Temperatura do modelo (opcional, padrão 0.2)
LLM_TEMPERATURE=0.2

# --- Chaves de API (preencha apenas a do provedor escolhido) ---
# Groq  -> https://console.groq.com/keys  (free tier)
GROQ_API_KEY=

# Google Gemini -> https://aistudio.google.com/app/apikey  (free tier)
GOOGLE_API_KEY=

# OpenAI -> https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- API de câmbio (AwesomeAPI - pública, não requer chave) ---
# Deixe como está, a menos que queira apontar para outro endpoint.
EXCHANGE_API_URL=https://economia.awesomeapi.com.br/last
